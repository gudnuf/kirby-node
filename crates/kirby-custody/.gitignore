/target
result
result-*
# Persisted dealer keyset (contains secret shares; throwaway zero-funds Mutinynet
# demo key, regenerated by spend-demo if absent). Never commit secret shares.
kirby-custody-keyset.json
# Refreshed keyset (C-5; also holds secret signing material). Never commit it.
kirby-custody-refreshed.json
# Single-shot spend markers (record the last spend so reruns do not re-spend).
kirby-custody-last-spend.txt
kirby-custody-g5-spend.txt
# Faucet JWT must stay out of the repo (read from the external FAUCET_JWT_PATH/env).
faucet-jwt.txt
*.jwt
